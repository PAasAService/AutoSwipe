# Copy to .env and fill values. Restart Metro after changes.

# API (must match Next.js port in dev)
EXPO_PUBLIC_API_BASE_URL=http://localhost:3002

# Public app URL (for sharing listing links)
# In production, set this to your actual domain (e.g., https://autoswipe.app)
# In development, it defaults to http://localhost:3002
# This is used when sharing listings from the native app.
EXPO_PUBLIC_APP_URL=http://localhost:3002

# Optional: override port when remapping localhost → LAN
# EXPO_PUBLIC_API_DEV_PORT=3002

# ─── SSO (same pattern as Apple: native gets idToken → POST /api/auth/oauth) ───
#
# Apple — configured in Xcode / app.json (usesAppleSignIn). Server: APPLE_CLIENT_ID=com.autoswipe.native
#
# Google — OAuth 2.0 Client IDs from Google Cloud Console (APIs & Services → Credentials):
#
# 1) Web application client (required for Expo Go + token verification)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
#
# 2) iOS client — Bundle ID com.autoswipe.native (dev build / App Store). Falls back to WEB if empty.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
#
# 3) Android — optional; create Android OAuth client with package com.autoswipe.native + SHA-1
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
#
# Server (autoswipe/.env): list EVERY client id_token may use, comma-separated, e.g.
#   GOOGLE_CLIENT_ID=web-xx.apps.googleusercontent.com,ios-yy.apps.googleusercontent.com
# Same variable names as optional splits: GOOGLE_WEB_CLIENT_ID, GOOGLE_IOS_CLIENT_ID, GOOGLE_ANDROID_CLIENT_ID
