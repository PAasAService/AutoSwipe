# ─── Database ─────────────────────────────────────────────────────────────────
# Prisma schema uses SQLite (see prisma/schema.prisma). Use a file URL for local dev:
DATABASE_URL="file:./dev.db"
# To use PostgreSQL instead: set provider = "postgresql" in prisma/schema.prisma, then e.g.:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/autoswipe"

# ─── Cron (secured jobs: expire listings, price alerts) ───────────────────────
# openssl rand -hex 32
CRON_SECRET=""

# ─── SSO (POST /api/auth/oauth) — same flow for Google & Apple: native sends idToken ──
#
# Apple — id_token `aud` must be listed here (comma-separated):
#   • Native / TestFlight: com.autoswipe.native (bundle ID)
#   • Expo Go (next dev only): host.exp.Exponent is auto-allowed in code — still set real bundle ID above.
APPLE_CLIENT_ID=""
#
# Google — id_token `aud` must match an OAuth 2.0 Client ID from Google Cloud Console.
# Put every client ID your app uses (comma-separated), same as you set in autoswipe-native/.env:
#   • Web client — required for Expo Go + server verification (use as GOOGLE_CLIENT_ID)
#   • iOS client — iOS dev build / App Store (bundle com.autoswipe.native); add to list below
#   • Android client — optional; add if different from Web
GOOGLE_CLIENT_ID=""
# Optional splits (merged with GOOGLE_CLIENT_ID by the API):
# GOOGLE_WEB_CLIENT_ID=""
# GOOGLE_IOS_CLIENT_ID=""
# GOOGLE_ANDROID_CLIENT_ID=""
# Optional duplicate for Next.js client bundles:
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""

# ─── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="AutoSwipe"

# ─── Listing images ─────────────────────────────────────────────────────────
# Stored under public/uploads (see .gitignore). No third-party image host env vars.

# ─── Email (Resend) ────────────────────────────────────────────────────────────
# Get from: resend.com (free: 3000 emails/month)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="noreply@your-domain.com"

# ─── AI (Anthropic) ───────────────────────────────────────────────────────────
# Get from: console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-xxxxxxxxxxxx"

# ─── Monitoring ───────────────────────────────────────────────────────────────
# Sentry: get DSN from sentry.io (free tier)
NEXT_PUBLIC_SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"
SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"
SENTRY_ORG="your-org"
SENTRY_PROJECT="autoswipe"

# ─── Analytics ────────────────────────────────────────────────────────────────
# PostHog: get from posthog.com (free: 1M events/month)
NEXT_PUBLIC_POSTHOG_KEY="phc_xxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# ─── Fuel prices (Israel, update periodically) ────────────────────────────────
NEXT_PUBLIC_FUEL_PRICE_GASOLINE=7.20
NEXT_PUBLIC_FUEL_PRICE_DIESEL=6.80
NEXT_PUBLIC_FUEL_PRICE_ELECTRIC_KWH=0.55
NEXT_PUBLIC_AVG_MONTHLY_KM=1500
